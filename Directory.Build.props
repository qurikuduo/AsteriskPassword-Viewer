<Project>
  <PropertyGroup Condition="'$(MSBuildProjectExtension)' == '.vcxproj' and '$(MSBuildProjectName)' == 'AsteriskPassword'">
    <BaseIntermediateOutputPath>$(MSBuildProjectDirectory)\AsteriskPassword\obj\</BaseIntermediateOutputPath>
    <MSBuildProjectExtensionsPath>$(BaseIntermediateOutputPath)</MSBuildProjectExtensionsPath>
  </PropertyGroup>
</Project>